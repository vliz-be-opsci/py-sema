@prefix ex: <http://example.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix schema: <http://schema.org/> .

<http://example.org/org/alpha> a schema:Organization ;
    foaf:name "Alpha Lab" ;
    schema:identifier "ALPHA" .

<http://example.org/org/beta> a schema:Organization ;
    foaf:name "Beta Lab" ;
    schema:identifier "BETA" .
